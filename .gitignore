# ── Kubernetes credentials ─────────────────────────────────────────────────────
k3s/kubeconfig.yaml
kubeconfig
kubeconfig.yaml
*.kubeconfig

# ── Site-specific Helm overrides (private IPs, cluster-specific settings) ──────
