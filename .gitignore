values-tr.yaml
values-*.local.yaml

# ── Environment files / secrets ────────────────────────────────────────────────
.env
.env.*
*.env
!.env.example

# ── OAuth & API tokens ─────────────────────────────────────────────────────────
google_oauth.json
*_oauth.json
*_token.json

# ── TLS / private key material ─────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ── Rendered Helm output (may contain secrets) ─────────────────────────────────
helm-output/
rendered/

# ── Claude Code ────────────────────────────────────────────────────────────────
.claude/

# ── OS / editor noise ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
